<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zjl.knowledge.mapper.KbDocumentChunkLogMapper">

    <select id="countByStatus" resultType="java.util.HashMap">
        SELECT status, COUNT(*) AS cnt
        FROM kb_document_chunk_log
        GROUP BY status
    </select>

    <select id="avgTotalDuration" resultType="java.lang.Long">
        SELECT COALESCE(AVG(total_duration_ms), 0)
        FROM kb_document_chunk_log
    </select>

    <select id="selectAllDurations" resultType="java.lang.Long">
        SELECT total_duration_ms
        FROM kb_document_chunk_log
        WHERE total_duration_ms IS NOT NULL
        ORDER BY total_duration_ms
    </select>

</mapper>
